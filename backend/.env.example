# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/retrevr

# Auth
SECRET_KEY=generate-a-secure-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_BASE_URL=https://your-backend.run.app

# OpenAI
OPENAI_API_KEY=

# S3/R2 Storage
S3_BUCKET_NAME=retrevr-recordings
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Redis (for rate limiting, event bus, campaign queue)
REDIS_URL=redis://localhost:6379/0

# Sentry (error tracking)
SENTRY_DSN=

# CORS — JSON list of allowed origins (production: your domain only)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
