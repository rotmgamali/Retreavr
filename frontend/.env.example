# Database (Supabase PostgreSQL)
POSTGRES_HOST=your-project-ref.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# JWT Auth
JWT_SECRET=generate-a-secure-key-here

# Backend URL (for API proxy rewrites in next.config.mjs)
BACKEND_URL=http://localhost:8000

# Supabase (for client-side SDK, if used)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (for voice agent / realtime features)
OPENAI_API_KEY=

# Twilio (for telephony / voice calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# S3/R2 Storage (for call recordings)
S3_BUCKET_NAME=retrevr-recordings
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Seed data (optional, dev only)
SEED_SECRET=
